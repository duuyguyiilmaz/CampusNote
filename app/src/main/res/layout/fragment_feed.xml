<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">


    <TextView
        android:id="@+id/tvFeedTitle"
        style="@style/AppText.Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ders Notları"
        android:textColor="@color/white"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="36dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvFeedSubtitle"
        style="@style/AppText.Subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Bölümündeki notları keşfet!"
        android:textColor="#AAB6D6"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="0dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvFeedTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFeed"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="92dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvFeedSubtitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <LinearLayout
        android:id="@+id/layoutLocked"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚"
            android:textSize="72sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            style="@style/AppText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Henüz not yüklemedin!"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            style="@style/AppText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tüm ders notlarına ulaşmak için&#10;sen de hemen bir not paylaş!"
            android:textColor="#AAB6D6"
            android:gravity="center"
            android:lineSpacingExtra="0dp"
            android:layout_marginBottom="36dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpload"
            style="@style/AppText.Button"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="Not Yükle"
            android:textColor="@color/text_white"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            app:cornerRadius="28dp"
            app:backgroundTint="#1E2D5A"
            app:elevation="6dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>