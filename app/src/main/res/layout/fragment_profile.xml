<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">


        <TextView
            style="@style/AppText.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Profilim"
            android:textColor="@color/white"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            app:cardCornerRadius="45dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A2A55">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="👤"
                android:textSize="36sp"
                android:textColor="@color/white"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/glass_card_bg"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉️"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppText.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"/>

                    <TextView
                        android:id="@+id/tvEmail"
                        style="@style/AppText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/white"/>
                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/glass_card_bg"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppText.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bölüm"/>

                    <TextView
                        android:id="@+id/tvDepartment"
                        style="@style/AppText.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/white"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvMyNotesTitle"
                style="@style/AppText.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notlarım"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/tvNoteCount"
                style="@style/AppText.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 not"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutEmptyNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\uD83D\uDCEC"
                android:textSize="48sp"/>

            <TextView
                android:id="@+id/tvEmptyTitle"
                style="@style/AppText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Henüz not yüklemedin"
                android:textColor="@color/white"
                android:layout_marginTop="8dp"/>

            <TextView
                style="@style/AppText.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İlk notunu paylaş!"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMyNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"/>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/AppText.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Çıkış Yap"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/primary"
            app:strokeWidth="0dp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconTint="@color/white"
            app:iconGravity="textStart"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>