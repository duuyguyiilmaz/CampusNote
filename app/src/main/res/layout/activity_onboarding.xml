<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/tvTitle"
        style="@style/AppText.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nasıl çalışır?"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/cardOne"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:background="@drawable/glass_card_bg"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            style="@style/AppText.StepNumber"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="1"
            android:gravity="center"
            android:background="@drawable/rounded_number_bg"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/AppText.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not paylaşarak puan kazan"/>

            <TextView
                style="@style/AppText.CardBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ders notlarını paylaştıkça puanın artar, sıralamalarda yükselirsin."
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/cardTwo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:background="@drawable/glass_card_bg"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardOne"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            style="@style/AppText.StepNumber"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="2"
            android:gravity="center"
            android:background="@drawable/rounded_number_bg"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/AppText.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100 puana ulaşınca ödül kazan"/>

            <TextView
                style="@style/AppText.CardBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100 puana ulaştığında seçili restoranlarda %15 indirim kazanırsın."
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/cardThree"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:background="@drawable/glass_card_bg"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardTwo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <TextView
            style="@style/AppText.StepNumber"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="3"
            android:gravity="center"
            android:background="@drawable/rounded_number_bg"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/AppText.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kampüs avantajlarına eriş"/>

            <TextView
                style="@style/AppText.CardBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anlaşmalı kafe ve restoranlarda özel indirimlerden yararlan."
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        style="@style/AppText.Button"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Hadi başlayalım"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:maxLines="1"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/cardThree"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>