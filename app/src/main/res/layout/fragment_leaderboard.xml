<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background">

    <!-- BAŞLIK -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/tvLeaderboardTitle"
            style="@style/AppText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Liderlik Tablosu"
            android:textColor="@color/soft_orange"/>

        <TextView
            android:id="@+id/tvLeaderboardSubtitle"
            style="@style/AppText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="En çok oylanan notlar burada!"
            android:textColor="#AAB6D6"/>
    </LinearLayout>

    <!-- MADALYA BADGE'LERİ -->
    <LinearLayout
        android:id="@+id/layoutBadges"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="14dp">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A2A55"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="🥇 Altın"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFD700"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A2A55"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="🥈 Gümüş"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#C0C0C0"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A2A55">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="🥉 Bronz"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#CD7F32"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- AYIRICI ÇİZGİ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E437A"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"/>

    <!-- RECYCLERVIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="92dp"
        android:clipToPadding="false"/>

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆"
            android:textSize="64sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            style="@style/AppText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Henüz sıralama yok"
            android:textColor="@color/soft_orange"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            style="@style/AppText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not paylaşıldıkça ve oylandıkça\nliderlik tablosu oluşacak!"
            android:textColor="#AAB6D6"
            android:gravity="center"/>
    </LinearLayout>

</LinearLayout>